# Copy this file to ".env" and fill in your own values.
# The .env file is ignored by git so your credentials stay private.

# Your MongoDB Atlas connection string.
# In Atlas: Database > Connect > Drivers > copy the string, then replace
# <username>, <password> and add your database name (keytroupeeDB).
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/keytroupeeDB?retryWrites=true&w=majority

# Port the API listens on (optional, defaults to 3000).
PORT=3000
